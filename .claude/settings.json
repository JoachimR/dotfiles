{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(glab *)",
      "Bash(glab:*)"
    ]
  },
  "hooks": {
    "Notification": [],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --is-inside-work-tree > /dev/null 2>&1 && git add . || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/joachimreiss/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); dir=$(echo \"$input\" | jq -r '.workspace.project_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); branch=$(git --git-dir=\"$dir/.git\" symbolic-ref --short HEAD 2>/dev/null); if [ -n \"$branch\" ]; then echo \"$model in $dir [$branch]\"; else echo \"$model in $dir\"; fi"
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Working"
    ]
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "high"
}
